{
  "name": "coping-cards",
  "description": "App Expo (RN) para coping cards: respiração guiada, cartões personalizados, TTS e música de fundo.",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "overrides": {
    "react-test-renderer": "18.2.0",
    "tar": ">=7.5.11",
    "fast-xml-parser": ">=5.5.7",
    "@tootallnate/once": ">=3.0.1",
    "braces": ">=3.0.3",
    "semver": ">=7.5.2",
    "xml2js": ">=0.5.0",
    "@xmldom/xmldom": ">=0.8.12",
    "send": ">=0.19.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "prepare": "if [ -d .git ]; then husky install; else echo \"Skipping husky (no .git)\"; fi",
    "build": "npm run build:web && node ./scripts/prepare-web-build.cjs",
    "build:android": "eas build -p android --profile production",
    "build:android:preview": "eas build -p android --profile preview",
    "build:android:dev": "eas build -p android --profile development",
    "build:ios": "eas build -p ios --profile production",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:ios:dev": "eas build -p ios --profile development",
    "build:web": "expo export --platform web --output-dir dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.10.1",
    "expo": "~51.0.28",
    "expo-asset": "~10.0.10",
    "expo-av": "~14.0.5",
    "expo-crypto": "~13.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~15.1.0",
    "expo-speech": "~12.0.1",
    "expo-splash-screen": "~0.27.5",
    "i18next": "^23.11.5",
    "nativewind": "^4.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^14.1.2",
    "react-native": "0.74.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^12.5.4",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "react-native-svg-transformer": "^1.3.0",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|react-clone-referenced-element|@react-navigation|@react-native-async-storage|expo|expo-.*|@expo|@expo/.*|expo-modules-core)"
    ]
  }
}
